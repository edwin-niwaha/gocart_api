ENVIRONMENT=production
DJANGO_SETTINGS_MODULE=core.settings.production
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-another-long-random-secret
ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com
DATABASE_URL=postgres://<db-user>:<db-password>@<db-host>:5432/<db-name>
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
TIME_ZONE=Africa/Kampala
LOG_LEVEL=INFO
DJANGO_REQUEST_LOG_LEVEL=WARNING
ENABLED_CHECKOUT_PAYMENT_METHODS=CASH
ENABLE_EMAIL=True
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
SUPPORT_EMAIL=
ENABLE_FIREBASE=False
FIREBASE_SERVICE_ACCOUNT_PATH=/app/core/firebase/service-account.json
ENABLE_MOMO=False
SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_CALLBACK_URL=
MOMO_BASE_URL=
MOMO_TARGET_ENVIRONMENT=production
MOMO_CURRENCY=UGX
ENABLE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SENTRY_DSN=
