ENVIRONMENT=development
DJANGO_SETTINGS_MODULE=core.settings.development
DEBUG=True

# Generate long random secrets locally; do not reuse across environments.
SECRET_KEY=replace-with-a-long-random-dev-secret
JWT_SECRET_KEY=replace-with-another-long-random-dev-secret

ALLOWED_HOSTS=127.0.0.1,localhost,[::1]
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
DEV_ALLOWED_HOSTS=
DEV_CSRF_TRUSTED_ORIGINS=

DATABASE_URL=sqlite:///db.sqlite3
POSTGRES_DB=gocart
POSTGRES_USER=gocart
POSTGRES_PASSWORD=change-me
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
TIME_ZONE=Africa/Kampala
LOG_LEVEL=INFO
DJANGO_REQUEST_LOG_LEVEL=WARNING
ENABLED_CHECKOUT_PAYMENT_METHODS=CASH

ENABLE_EMAIL=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@gocart.local
SUPPORT_EMAIL=support@gocart.local

ENABLE_FIREBASE=False
FIREBASE_SERVICE_ACCOUNT_PATH=core/firebase/service-account.json

ENABLE_MOMO=False
SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_CALLBACK_URL=
MOMO_BASE_URL=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CURRENCY=UGX

ENABLE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SENTRY_DSN=
